PORT=4000
NODE_ENV=development

# Required for authentication and session signing
JWT_SECRET=replace-with-a-long-random-secret
JWT_TTL_SECONDS=43200
JWT_ISSUER=restohub
JWT_AUDIENCE=restohub-client

# Optional development bootstrap account
RESTOHUB_BOOTSTRAP_ADMIN_PASSWORD=change-me-in-development-only

# Preferred connection string for PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/restohub

# Optional fallback fields if you do not use DATABASE_URL
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=password
# PGDATABASE=restohub
# PGSSL=false
# PGPOOL_MAX=10# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
