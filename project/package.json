{
  "name": "restohub-db-updates",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:frontend": "npm --workspace frontend run dev",
    "dev:backend": "npm --workspace backend run dev",
    "build:frontend": "npm --workspace frontend run build",
    "lint:frontend": "npm --workspace frontend run lint",
    "db:init": "npm --workspace backend run db:init",
    "test:api": "npm --workspace backend run test:api",
    "test:rbac": "npm --workspace backend run test:rbac"
  }
}